#!/usr/bin/env bash

if ! command -v claude &>/dev/null; then
  echo "Claude Code is not installed. Install it with:"
  echo ""
  echo "  npm install -g @anthropic-ai/claude-code"
  echo ""
  exit 1
fi

branch=$(git branch --show-current 2>/dev/null)
if [ -z "$branch" ]; then
  claude "$@"
  exit $?
fi

project_key=$(pwd | sed 's|/|-|g')
project_dir="$HOME/.claude/projects/${project_key}"

if [ ! -d "$project_dir" ]; then
  echo "New session for branch: $branch"
  claude "$@"
  exit $?
fi

# Extract a JSON string field value from a line: extract_field <line> <fieldname>
extract_field() {
  printf '%s' "$1" \
    | grep -oE "\"$2\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" \
    | grep -oE '"[^"]*"$' \
    | tr -d '"'
}

best_session=""
best_ts=""

for f in "$project_dir"/*.jsonl; do
  [ -f "$f" ] || continue
  sid=$(basename "$f" .jsonl)
  first_branch=""
  last_ts=""

  while IFS= read -r line; do
    # Skip lines that are not user messages or lack gitBranch
    echo "$line" | grep -qF '"type"' || continue
    [ "$(extract_field "$line" "type")" = "user" ] || continue
    gb=$(extract_field "$line" "gitBranch")
    [ -n "$gb" ] || continue

    [ -n "$first_branch" ] || first_branch="$gb"
    ts=$(extract_field "$line" "timestamp")
    [ -n "$ts" ] && last_ts="$ts"
  done < "$f"

  if [ "$first_branch" = "$branch" ] && [ -n "$last_ts" ]; then
    if [[ "$last_ts" > "$best_ts" ]]; then
      best_ts="$last_ts"
      best_session="$sid"
    fi
  fi
done

if [ -n "$best_session" ]; then
  echo "Resuming session for branch: $branch"
  claude --resume "$best_session" "$@"
else
  echo "New session for branch: $branch"
  claude "$@"
fi
